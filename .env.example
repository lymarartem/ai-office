# ─── Telegram Bot Tokens (создай через @BotFather) ───────────────────────────
CEO_BOT_TOKEN=your_ceo_bot_token_here
MARKETING_BOT_TOKEN=your_marketing_bot_token_here
DEVELOPER_BOT_TOKEN=your_developer_bot_token_here
DESIGN_BOT_TOKEN=your_design_bot_token_here

# ─── AI Backend: выбери "anthropic", "groq" или "ollama" ─────────────────────
AI_BACKEND=groq

# ─── Groq (если AI_BACKEND=groq) — бесплатно, console.groq.com ───────────────
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# ─── Anthropic (если AI_BACKEND=anthropic) ───────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# ─── Ollama (если AI_BACKEND=ollama) ─────────────────────────────────────────
OLLAMA_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5:14b
